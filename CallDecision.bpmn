      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="TextAnnotation_1" id="BPMNShape_TextAnnotation_1">
        <omgdc:Bounds height="50.0" width="120.0" x="551.0" y="145.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="startnoneevent1" id="BPMNShape_startnoneevent1">
        <omgdc:Bounds height="30.0" width="30.0" x="427.0" y="274.0"></omgdc:Bounds>
      </bpmndi:BPMNShape>
