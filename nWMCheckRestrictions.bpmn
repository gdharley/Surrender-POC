  <process id="nWMCheckRestrictions" name="NWM Check Restrictions" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-06-25T21:46:14.408Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-07-02T21:28:29.671Z]]></design:modificationdate>
    </extensionElements>
    <userTask id="FormTask_3" name="Check Restrictions" flowable:assignee="${initiator}" flowable:formKey="nWMCheckRestrictions" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <serviceTask id="VariableActivity_7" name="Set Case Status" flowable:delegateExpression="${initVariablesService}" flowable:type="init-variables" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping target="root" name="caseStatus" valueType="string" value="In Progress - Transaction Review"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="VariableActivity_8" name="Set Restrictions Status - approved" flowable:delegateExpression="${initVariablesService}" flowable:type="init-variables" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping name="restrictionsStatus" valueType="string" value="approved"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <callActivity id="CallActivity_8" name="Check for Auto Approve" calledElement="CallDecision" flowable:sameDeployment="true" flowable:fallbackToDefaultTenant="true">
      <extensionElements>
        <flowable:in source="initiator" target="initiator"></flowable:in>
        <flowable:in source="policy" target="policy"></flowable:in>
        <flowable:in source="restrictionsStatus" target="restrictionsStatus"></flowable:in>
        <flowable:out source="canBypass" target="canBypass"></flowable:out>
        <design:stencilid><![CDATA[CallActivity]]></design:stencilid>
      </extensionElements>
    </callActivity>
    <serviceTask id="VariableActivity_14" name="Set Restrictions Status - denied" flowable:delegateExpression="${initVariablesService}" flowable:type="init-variables" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping name="restrictionsStatus" valueType="string" value="denied"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_14" name="DEbug Check Restrictios" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <serviceTask id="EmailTask_14" name="Notify Policy Holder" flowable:type="mail">
      <extensionElements>
        <flowable:field name="to">
          <flowable:string><![CDATA[greg.harley@flowable.com]]></flowable:string>
        </flowable:field>
        <flowable:field name="subject">
          <flowable:string><![CDATA[Policy Surrender Request Denied]]></flowable:string>
        </flowable:field>
        <flowable:field name="html">
          <flowable:expression><![CDATA[<p>Hello ${policy.holder.firstName},<br><br>We are writing to inform you that unfortunately your request to surrendert policy ${policy.policyNumber} has been declined.<br><br>If you have any questions, please contact our customer engagement team.<br><br>Yours,<br>The company<br><br><br></p>]]></flowable:expression>
        </flowable:field>
        <design:stencilid><![CDATA[EmailTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <exclusiveGateway id="Exclusive_Databased_Gateway_8" default="SequenceFlow_11">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
      </extensionElements>
    </exclusiveGateway>
    <exclusiveGateway id="Exclusive_Databased_Gateway_9" default="SequenceFlow_13">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
      </extensionElements>
    </exclusiveGateway>
