    <sequenceFlow id="SequenceFlow_15" sourceRef="Exclusive_Databased_Gateway_9" targetRef="EmailTask_14">
      <extensionElements>
        <flowable:condition group="true" match="all" targetAttribute="condition">
          <flowable:condition sourceVariableType="variable" sourceName="restrictionsStatus" operator="equals" targetVariableType="value" targetValue="denied" targetType="string"></flowable:condition>
        </flowable:condition>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${vars:equals(restrictionsStatus, 'denied')}]]></conditionExpression>
    </sequenceFlow>
