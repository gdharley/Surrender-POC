  <process id="nWMProcessSurrender" name="NWM Process Surrender" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-06-25T21:46:14.404Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-07-02T21:28:29.671Z]]></design:modificationdate>
    </extensionElements>
    <serviceTask id="VariableActivity_1" name="Set Case Status" flowable:delegateExpression="${initVariablesService}" flowable:type="init-variables" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping target="root" name="caseStatus" valueType="string" value="Scheduled to Process"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_3" name=" Debug Processing" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <serviceTask id="ServiceRegistryTask_7" name="Get Surrender Value" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="nWmMfService" operationKey="getSurrenderValue"></flowable:serviceMapping>
        <flowable:inputParameter name="policyId" value="${policy.id}"></flowable:inputParameter>
        <flowable:outputParameter name="surrenderValue" value="surrenderValue"></flowable:outputParameter>
        <flowable:outputParameter name="currency" value="currency"></flowable:outputParameter>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceRegistryTask_12" name="Send Details to Fraud" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="nWmMfService" operationKey="startFraudInvestigation"></flowable:serviceMapping>
        <flowable:inputParameter name="payload" value="${policy}"></flowable:inputParameter>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_17" name="Fraud Done" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <startEvent id="startnoneevent1" flowable:initiator="initiator" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
      </extensionElements>
    </startEvent>
    <intermediateCatchEvent id="IntermediateEventRegistryEventCatching_12">
      <extensionElements>
        <flowable:eventType>nWMFraudResults</flowable:eventType>
        <flowable:eventCorrelationParameter name="instanceId" value="${root.id}"></flowable:eventCorrelationParameter>
        <flowable:startEventCorrelationConfiguration><![CDATA[startNewInstance]]></flowable:startEventCorrelationConfiguration>
        <flowable:eventOutParameter source="status" target="status"></flowable:eventOutParameter>
        <flowable:eventOutParameter source="notes" target="description"></flowable:eventOutParameter>
        <design:stencilid><![CDATA[IntermediateEventRegistryEventCatching]]></design:stencilid>
      </extensionElements>
    </intermediateCatchEvent>
    <endEvent id="EndNoneEvent_5">
