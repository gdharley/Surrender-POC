  <process id="nWMGenericEsignProcess" name="NWM Generic Esign process" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-06-25T21:46:14.409Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-06-25T21:46:14.409Z]]></design:modificationdate>
    </extensionElements>
    <subProcess id="ExpandedSubProcess_15" name="generate Content items">
      <extensionElements>
        <design:stencilid><![CDATA[ExpandedSubProcess]]></design:stencilid>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="true" flowable:collection="${signedDocs}" flowable:elementVariable="theDoc">
        <extensionElements></extensionElements>
      </multiInstanceLoopCharacteristics>
      <serviceTask id="ServiceRegistryTask_17" name="Gert Document Content" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
        <extensionElements>
          <flowable:serviceMapping serviceModelKey="genericEsignService" operationKey="getDocumentContent"></flowable:serviceMapping>
          <flowable:inputParameter name="envelopeId" value="${envelopeId}"></flowable:inputParameter>
          <flowable:inputParameter name="documentId" value="${theDoc.documentId}"></flowable:inputParameter>
          <flowable:outputParameter name="contentType" value="contentType"></flowable:outputParameter>
          <flowable:outputParameter name="data" value="docData"></flowable:outputParameter>
          <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
          <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
        </extensionElements>
      </serviceTask>
      <serviceTask id="CreateDocumentTask_17" name="Create document" flowable:delegateExpression="${createDocumentService}" flowable:type="create-document">
        <extensionElements>
          <design:stencilid><![CDATA[CreateDocumentTask]]></design:stencilid>
          <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
          <flowable:documentContent><![CDATA[${docData}]]></flowable:documentContent>
          <flowable:outputDocumentName><![CDATA[${envelopeId}]]></flowable:outputDocumentName>
          <flowable:outputDocumentMimeType><![CDATA[${contentType}]]></flowable:outputDocumentMimeType>
          <flowable:outputVariableName><![CDATA[myDoc]]></flowable:outputVariableName>
        </extensionElements>
      </serviceTask>
      <startEvent id="StartNoneEvent_17" flowable:initiator="initiator" flowable:formFieldValidation="false">
        <extensionElements>
          <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
          <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
        </extensionElements>
      </startEvent>
      <endEvent id="EndNoneEvent_20">
        <extensionElements>
          <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        </extensionElements>
      </endEvent>
      <sequenceFlow id="SequenceFlow_19" sourceRef="ServiceRegistryTask_17" targetRef="CreateDocumentTask_17">
        <extensionElements>
          <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
        </extensionElements>
      </sequenceFlow>
      <sequenceFlow id="SequenceFlow_21" sourceRef="CreateDocumentTask_17" targetRef="EndNoneEvent_20">
        <extensionElements>
          <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
        </extensionElements>
      </sequenceFlow>
      <sequenceFlow id="SequenceFlow_18" sourceRef="StartNoneEvent_17" targetRef="ServiceRegistryTask_17">
        <extensionElements>
          <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
        </extensionElements>
      </sequenceFlow>
    </subProcess>
    <serviceTask id="ServiceRegistryTask_3" name="Get eSign Account" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="genericEsignService" operationKey="getUserInfo"></flowable:serviceMapping>
        <flowable:inputParameter name="email" value="${signerEmail}"></flowable:inputParameter>
        <flowable:outputVariableName><![CDATA[account]]></flowable:outputVariableName>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceTask_3" name="Base64 Encode Document" flowable:expression="${flw.base64.encodeToString(document)}" flowable:resultVariableName="encodedDocument" flowable:storeResultVariableAsTransient="true">
      <extensionElements>
        <design:stencilid><![CDATA[ServiceTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceRegistryTask_6" name="Create eSign Envelope" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="genericEsignService" operationKey="createEnvelope"></flowable:serviceMapping>
        <flowable:inputParameter name="signerName" value="${account.name}"></flowable:inputParameter>
        <flowable:inputParameter name="signerEmail" value="${signerEmail}"></flowable:inputParameter>
        <flowable:inputParameter name="accountId" value="${account.accounts[0].accountId}"></flowable:inputParameter>
        <flowable:inputParameter name="documentName" value="Test_Document"></flowable:inputParameter>
        <flowable:inputParameter name="documentContent" value="${encodedDocument}"></flowable:inputParameter>
        <flowable:outputParameter name="envelopeId" value="envelopeId"></flowable:outputParameter>
        <flowable:outputParameter name="status" value="eSignStatus"></flowable:outputParameter>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceRegistryTask_13" name="Get Documents" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="genericEsignService" operationKey="listEnvelopeDocuments"></flowable:serviceMapping>
        <flowable:inputParameter name="envelopeId" value="${envelopeId}"></flowable:inputParameter>
        <flowable:outputParameter name="documents" value="signedDocs"></flowable:outputParameter>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceRegistryTask_24" name="Get Status" flowable:asyncLeave="true" flowable:delegateExpression="${serviceRegistryService}" flowable:type="service-registry" flowable:extensionId="ServiceRegistryTask">
      <extensionElements>
        <flowable:serviceMapping serviceModelKey="genericEsignService" operationKey="getEnvelopeStatus"></flowable:serviceMapping>
        <flowable:inputParameter name="envelopeId" value="${envelopeId}"></flowable:inputParameter>
        <flowable:outputParameter name="status" value="eSignStatus"></flowable:outputParameter>
        <design:stencilid><![CDATA[ServiceRegistryTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_28" name="Process Status (testing)" flowable:assignee="${initiator}" flowable:formKey="nWMUpdateESignStatusToDemoClientDeclined" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
