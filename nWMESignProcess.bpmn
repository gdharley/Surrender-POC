  <process id="nWMESignProcess" name="NWM eSign Process" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-06-25T21:46:14.395Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-07-02T21:28:29.670Z]]></design:modificationdate>
    </extensionElements>
    <userTask id="FormTask_1" name="Run eSign" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <callActivity id="CallActivity_3" name="Generic eSign Process" calledElement="nWMGenericEsignProcess" flowable:sameDeployment="true" flowable:fallbackToDefaultTenant="true">
      <extensionElements>
        <flowable:in source="initiator" target="initiator"></flowable:in>
        <flowable:in source="request" target="request"></flowable:in>
        <flowable:in source="policyDoc" target="document"></flowable:in>
        <flowable:in sourceExpression="${policy.holder.email}" target="signerEmail"></flowable:in>
        <flowable:out source="eSignStatus" target="eSignStatus"></flowable:out>
        <design:stencilid><![CDATA[CallActivity]]></design:stencilid>
      </extensionElements>
    </callActivity>
    <serviceTask id="VariableActivity_4" name="Initialize variables" flowable:delegateExpression="${initVariablesService}" flowable:type="init-variables" flowable:extensionId="VariableActivity">
      <extensionElements>
        <flowable:overwrite><![CDATA[true]]></flowable:overwrite>
        <flowable:variableMapping target="root" name="caseStatus" valueType="string" value="Initiated - Waiting for Form"></flowable:variableMapping>
        <design:stencilid><![CDATA[VariableActivity]]></design:stencilid>
        <design:stencilsuperid><![CDATA[ServiceTask]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <startEvent id="startnoneevent1" flowable:initiator="initiator" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
      </extensionElements>
    </startEvent>
    <endEvent id="EndNoneEvent_3">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
      </extensionElements>
    </endEvent>
    <sequenceFlow id="SequenceFlow_4" sourceRef="FormTask_1" targetRef="CallActivity_3">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_5" sourceRef="CallActivity_3" targetRef="EndNoneEvent_3">
      <extensionElements>
