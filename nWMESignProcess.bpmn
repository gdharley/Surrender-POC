    <sequenceFlow id="SequenceFlow_2" sourceRef="startnoneevent1" targetRef="VariableActivity_4">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <textAnnotation id="TextAnnotation_3">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[policy
request
policyDoc
initiator]]></design:text>
      </extensionElements>
      <text>policy
request
policyDoc
initiator</text>
    </textAnnotation>
    <textAnnotation id="TextAnnotation_4">
      <extensionElements>
        <design:stencilid><![CDATA[TextAnnotation]]></design:stencilid>
        <design:text><![CDATA[eSignStatus]]></design:text>
      </extensionElements>
      <text>eSignStatus</text>
    </textAnnotation>
    <association id="AssociationUndirected_4" sourceRef="TextAnnotation_3" targetRef="startnoneevent1" associationDirection="None">
      <extensionElements>
        <design:stencilid><![CDATA[AssociationUndirected]]></design:stencilid>
